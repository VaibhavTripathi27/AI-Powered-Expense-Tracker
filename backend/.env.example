# ── App ──────────────────────────────────────────────
PROJECT_NAME=AI Expense Tracker
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# ── Database (Neon/Postgres) ─────────────────────────
# Local:   postgresql://postgres:postgres@localhost:5432/expense_tracker
# Neon:    postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/expense_tracker

# ── Security / JWT ───────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS (comma-separated origins) ───────────────────
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Gemini AI ────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
